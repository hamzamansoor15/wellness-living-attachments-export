# Your WellnessLiving business ID (required).
# Find it in the URL bar when logged in — it appears as k_business=XXXXX
# on most pages (e.g. client profiles, reports).
K_BUSINESS=your_business_id_here

# Number of parallel browser tabs (default: 3).
# Higher values are faster but may trigger rate limits. Start at 2-3.
WORKER_COUNT=3

# Output directory for downloaded files (default: ./downloads).
DOWNLOAD_DIR=./downloads

# Set to "false" to watch the browser — useful for debugging login issues.
HEADLESS=true
